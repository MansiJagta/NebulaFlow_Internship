###################################
# ROOT LEVEL
###################################

# Dependency folders
node_modules/

# Environment variables (IMPORTANT - never push secrets)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Build / production output
dist/
build/

# OS metadata
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/

###################################
# FRONTEND (React / Vite)
###################################

frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/coverage/

###################################
# BACKEND (Node / Express)
###################################

backend/node_modules/
backend/dist/
backend/coverage/
backend/.env
backend/.env.local
backend/tmp/

# Runtime artifacts
*.pid
*.pid.lock

###################################
# DOCKER
###################################

docker-compose.override.yml
